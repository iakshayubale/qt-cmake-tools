# Ignore patterns for Qt CMake Tools

# CMake build directories
build/
Build/
.build/
cmake-build-*/
out/
_builds/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.user
*.user.*
*.creator.user
*.xcworkspace
*.kdev4

# Visual Studio
.vs/
*.vcxproj.user
*.sln.DotSettings
Debug/
Release/
*.db

# Xcode
*.xcodeproj
*.xcworkspace
DerivedData/
build/

# Qt-specific
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.o
*.so
*.a
*.lib
*.dll
*.dylib

# Build artifacts
*.exe
*.msi
*.app
*.apk

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.log

# Package managers
.conan/
conan.lock
vcpkg.json

# Documentation
docs/_build/
site/

# Coverage
coverage/
*.gcov
*.gcda
*.gcno

# OS-specific
Thumbs.db
.directory

# Python cache
__pycache__/
*.pyc
*.pyo

# Node modules (if using node-based tools)
node_modules/
package-lock.json

# Distribution
dist/
build-artifacts/

# Test results
test-results/
*.xml

# User-specific
.local/
.env
.env.local
secrets.txt

# Generated by cmake
CTestTestfile.cmake
